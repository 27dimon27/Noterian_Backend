# Server
# 1. Server port
PORT=8000
# 2. Read timeout for server
READ_TIMEOUT= 15
# 3. Write timeout for server
WRITE_TIMEOUT= 15
# 4. Idle timeout for server
IDLE_TIMEOUT= 15
# 5. Shutdown timeout for server
SHUTDOWN_TIMEOUT=5

# JWT
# 1. JWT-secret for token generation
JWT_SECRET=your_super_secret_key_here
# 2. Name of JWT-token cookie
COOKIE_NAME=NoterianCookieJWT
# 3. JWT-token lifetime
COOKIE_TIME_JWT=3600
# 4. Token transfer security flag (https)
IS_SECURE=false

# Database
# 1. Host of database
DB_HOST=postgres
# 2. Port of database
DB_PORT=5432
# 3. User of database
DB_USER=noterian_user
# 4. Password of database
DB_PASSWORD=noterian_password
# 5. Name of database
DB_NAME=noterian_db
# 6. SSL mode for connecting to database (disable/preferred/require/skip-verify/verify-ca/verify-full)
DB_SSL_MODE=disable
# 7. Maximum number of open connections to the database
MAX_OPEN_CONNECTIONS=25
# 8. Maximum number of idle-connections to the database
MAX_IDLE_CONNECTIONS=10

# MinIO
# 1. MinIO endpoint (host:port)
MINIO_ENDPOINT=localhost:9000
# 2. MinIO access key (username)
MINIO_ACCESS_KEY=minioadmin
# 3. MinIO secret key (password)
MINIO_SECRET_KEY=minioadmin
# 4. Use SSL for MinIO connection
MINIO_USE_SSL=false
# 5. Bucket name for attachments
MINIO_BUCKET_NAME=attachments

# Logging level
LOG_LEVEL=INFO